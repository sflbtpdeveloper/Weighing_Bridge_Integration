<mvc:View
    controllerName="zmwbi.controller.Create"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:core="sap.ui.core"
>
    <Page
        id="Create"
        showFooter="true"
        showHeader="false"
        showNavButton="false"
        class="sapUiNoContentPadding"
    >
        <content>
            <HBox
                class="videoHeader"
                alignItems="Center"
                justifyContent="SpaceBetween"
            >
                <HBox
                    alignItems="Center"
                    justifyContent="Start"
                    class="headerLeft sapUiNoMargin sapUiNoPadding"
                >
                    <Image
                        src="../images/sfllogoonly.png"
                        width="3rem"
                        class="sapUiSmallMarginEnd"
                    />
                    <VBox class="headerTextBox sapUiTinyMarginBegin">
                        <Title
                            text="SUNDRAM FASTENERS LIMITED"
                            class="videoHeaderTitle"
                        />
                        <Text
                            text="Weigh Bridge Integration"
                            class="videoHeaderSubTitle"
                        />
                    </VBox>
                </HBox>
            </HBox>

            <Toolbar>
                <HBox width="33%" />
                <HBox width="34%" justifyContent="Center">
                    <Title
                        text="FIRST - WEIGHMENT ENTRY"
                        textAlign="Center"
                        titleStyle="Auto"
                        class="sapUiTinyMarginBegin sapUiTinyMarginTop videoHeaderSubTitle"
                    />
                </HBox>
                <HBox width="33%" justifyContent="End">
                    <Button
                        text="SAVE"
                        press="onSave"
                        icon="sap-icon://save"
                        type="Accept"
                        enabled="{saveButtonModel>/isSaveEnabled}"
                    />
                </HBox>
            </Toolbar>

            <VBox
                alignItems="Center"
                class="sapUiSmallMarginTop sapUiSmallMarginBottom"
            >
                <Text
                    text="LIVE WEIGHT"
                    class="sapUiSmallMarginBottom subTitle"
                />

                <Text
                    text="{liveModel>/Weight}"
                    class="liveWeightText"
                />

                <Button
                    text="Capture Weight"
                    type="Emphasized"
                    press="onCaptureWeight"
                    icon="sap-icon://download"
                />
            </VBox>

            <VBox class="sapUiSmallMargin">
                <f:SimpleForm
                    id="SimpleFormChange456"
                    editable="true"
                    layout="ColumnLayout"
                    columnsM="2"
                    columnsL="2"
                    columnsXL="3"
                    title="Enter Weight (Header Details)"
                    backgroundDesign="Translucent"
                >
                    <f:content>
                        <Label text="Plant" />
                        <ComboBox
                            id="idWerk"
                            selectedKey="{TRIPMODEL>/Plant}"
                            selectionChange="onPlantChange"
                            items="{ path: '/plant' }"
                        >
                            <core:Item
                                key="{Plant}"
                                text="{Plant} - {PlantName}"
                            />
                        </ComboBox>

                        <Label text="Trip ID" />
                        <Input
                            id="idTripid"
                            value="{TRIPMODEL>/TripId}"
                            editable="false"
                        >
                            <layoutData>
                                <l:GridData span="XL2 L1 M3 S4" />
                            </layoutData>
                        </Input>

                        <Label text="Truck Number" />
                        <Input
                            id="idTrNo"
                            value="{TRIPMODEL>/Truckno}"
                            editable="true"
                        />

                        <Label text="Supplier Code" />
                        <ComboBox
                            id="idSupcode"
                            width="100%"
                            selectedKey="{TRIPMODEL>/Supcode}"
                            placeholder="Select Supplier Code"
                            items="{vendorModel>/results}"
                        >
                            <core:Item
                                key="{vendorModel>Vendor}"
                                text="{vendorModel>Vendor}"
                            />
                        </ComboBox>

                        <Label text="First Weight" />
                        <Input
                            id="idFW"
                            value="{TRIPMODEL>/Firstwgt}"
                            editable="false"
                            class="weightGreen"
                        />

                        <Label text="Second Weight" />
                        <Input
                            id="idSW"
                            value="{TRIPMODEL>/Secondwgt}"
                            editable="false"
                            class="weightGreen"
                        />

                        <Label text="Net Weight" />
                        <Input
                            id="idNW"
                            value="{TRIPMODEL>/Netwgt}"
                            editable="false"
                        />

                        <Label text="Unit" />
                        <Input
                            id="idUnit"
                            value="{TRIPMODEL>/Refunit}"
                            required="false"
                        />
                    </f:content>
                </f:SimpleForm>
            </VBox>

            <VBox class="sapUiSmallMargin">
                <Table
                    id="idItemTable"
                    items="{ItemModel>/results}"
                    growing="true"
                    growingThreshold="20"
                    headerText="Enter Weight (Item Details)"
                >
                    <columns>
                        <Column><Text text="Serial No" /></Column>
                        <Column><Text text="Invoice No" /></Column>
                        <Column><Text text="Invoice Date" /></Column>
                        <Column><Text text="Purchase Order No" /></Column>
                        <Column><Text text="Purchase Order Item" /></Column>
                        <Column><Text text="Material" /></Column>
                        <Column><Text text="Quantity/UOM" /></Column>
                        <Column width="80px"><Text text="Delete" /></Column>
                    </columns>

                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{ItemModel>Sino}" />

                                <Input
                                    value="{ItemModel>Invoiceno}"
                                    liveChange="onInvoiceNoLiveChange"
                                />

                                <DatePicker
                                    value="{ItemModel>Invoicedt}"
                                    displayFormat="dd-MM-yyyy"
                                    valueFormat="yyyy-MM-ddTHH:mm:ss"
                                    change="onFieldChange"
                                />

                                <ComboBox
                                    width="100%"
                                    selectedKey="{ItemModel>Pono}"
                                    selectionChange="onPurchaseOrderChange"
                                    items="{ItemModel>poNoItems}"
                                >
                                    <core:Item
                                        key="{ItemModel>purchaseorderno}"
                                        text="{ItemModel>purchaseorderno}"
                                    />
                                </ComboBox>

                                <ComboBox
                                    width="100%"
                                    selectedKey="{ItemModel>Poitem}"
                                    selectionChange="onPurchaseOrderItemChange"
                                    items="{ItemModel>poItemItems}"
                                >
                                    <core:Item
                                        key="{ItemModel>purchaseorderitem}"
                                        text="{ItemModel>purchaseorderitem}"
                                    />
                                </ComboBox>

                                <ComboBox
                                    width="100%"
                                    selectedKey="{ItemModel>Matnr}"
                                    selectionChange="onMaterialChange"
                                    items="{ItemModel>materialItems}"
                                >
                                    <core:Item
                                        key="{ItemModel>Material}"
                                        text="{ItemModel>Material}"
                                    />
                                </ComboBox>

                                <Input
                                    value="{ItemModel>Qty}"
                                    liveChange="onFieldChange"
                                />

                                <Button
                                    icon="sap-icon://delete"
                                    press="onDeleteRow"
                                />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>