<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:unified="sap.ui.unified"
    xmlns:core="sap.ui.core"
    controllerName="zmwbi.controller.Update"
>
    <Page
        id="Update"
        showFooter="true"
        showHeader="false"
        showNavButton="false"
        class="sapUiNoContentPadding"
    >
        <content>
            <HBox
                class="videoHeader"
                alignItems="Center"
                justifyContent="SpaceBetween"
            >
                <HBox
                    alignItems="Center"
                    justifyContent="Start"
                    class="headerLeft sapUiNoMargin sapUiNoPadding"
                >
                    <!-- <Image
                                src="../images/sfllogoonly.png"
                                width="3rem"
                                class="sapUiSmallMarginEnd"
                            /> -->
                    <VBox
                        class="logoImage"
                        width="4rem"
                        height="4rem"
                    />
                    <!-- <VBox class="headerTextBox sapUiTinyMarginBegin"> -->
                    <VBox>
                        <Title
                            text="SUNDRAM FASTENERS LIMITED"
                            class="videoHeaderTitle"
                        />
                        <Text
                            text="Weigh Bridge Integration"
                            class="videoHeaderSubTitle"
                        />
                    </VBox>
                </HBox>
            </HBox>
            <Toolbar>
                <HBox width="33%" />
                <HBox
                    width="34%"
                    justifyContent="Center"
                >
                    <Title
                        text="SECOND - WEIGHMENT ENTRY"
                        textAlign="Center"
                        titleStyle="Auto"
                        class="sapUiTinyMarginBegin sapUiTinyMarginTop videoHeaderSubTitle"
                    />
                </HBox>
                <HBox
                    width="33%"
                    justifyContent="End"
                >
                    <!-- <Button
                        text="UPDATE"
                        press="onUpdate"
                        icon="sap-icon://save"
                        type="Attention"
                        enabled="{saveButtonModel>/isSaveEnabled}"
                    /> -->
                </HBox>
            </Toolbar>

            <VBox
                alignItems="Center"
                class="sapUiSmallMarginTop sapUiSmallMarginBottom"
            >
                <Text
                    text="LIVE WEIGHT"
                    class="sapUiSmallMarginBottom"
                />

                <Text
                    text="{liveModel>/Weight}"
                    class="liveWeightText"
                />

                <Button
                    text="Capture Weight"
                    type="Emphasized"
                    press="onCaptureWeight"
                    icon="sap-icon://download"
                />
            </VBox>
            <VBox class="sapUiSmallMargin">
                <Toolbar>
                    <Title text="Enter Weight (Header Details)" />
                    <ToolbarSpacer />
                    <Button
                        text="UPDATE"
                        press="onUpdate"
                        icon="sap-icon://save"
                        type="Attention"
                        enabled="{saveButtonModel>/isSaveEnabled}"
                    />
                </Toolbar>
                <f:SimpleForm
                    id="SimpleFormChange456"
                    editable="true"
                    layout="ColumnLayout"
                    columnsM="2"
                    columnsL="2"
                    columnsXL="3"
                    backgroundDesign="Translucent"
                >
                    <f:content>
                        <Label text="Plant" />
                        <!-- <Input
                            id="idWerk"
                            value="{TRIPMODEL>/Plant}"
                            editable="true"
                        /> -->

                        <ComboBox
                            id="idWerk"
                            selectedKey="{TRIPMODEL>/Plant}"
                            items="{
        path: '/plant'
    }"
                        >
                            <core:Item
                                key="{Plant}"
                                text="{Plant} - {PlantName}"
                            />
                        </ComboBox>
                        <Label text="Trip ID" />
                        <Input
                            id="idTripid"
                            value="{TRIPMODEL>/TripId}"
                            editable="false"
                        >
                            <layoutData>
                                <l:GridData span="XL2 L1 M3 S4" />
                            </layoutData>
                        </Input>
                        <Label text="Truck Number" />
                        <Input
                            id="idTrNo"
                            value="{TRIPMODEL>/Truckno}"
                            editable="false"
                        />
                        <Label text="Supplier Code" />
                        <!-- <Input
                            id="idSupcode"
                            value="{TRIPMODEL>/Supcode}"
                            editable="true"
                        /> -->

                        <ComboBox
                            id="idVendor"
                            width="100%"
                            placeholder="Select Supplier"
                            selectionChange="onVendorChange"
                            selectedKey="{TRIPMODEL>/Supcode}"
                            items="{
                                        path: '/vendorF4'
                                    }"
                        >
                            <core:Item
                                key="{Vendor}"
                                text="{Vendor}"
                            />
                        </ComboBox>
                        <Label text="First Weight" />
                        <Input
                            id="idFW"
                            value="{TRIPMODEL>/Firstwgt}"
                            editable="false"
                            enabled="true"
                            class="weightGreen"
                        />

                        <Label text="Second Weight" />
                        <Input
                            id="idSW"
                            value="{TRIPMODEL>/Secondwgt}"
                            editable="false"
                            enabled="true"
                            class="weightGreen"
                        />

                        <Label text="Net Weight" />
                        <Input
                            id="idNW"
                            value="{TRIPMODEL>/Netwgt}"
                            editable="false"
                        />

                        <Label text="Unit" />
                        <Input
                            id="idUnit"
                            value="{TRIPMODEL>/Refunit}"
                            change="onInvoiceQtyChange"
                            required="false"
                        />
                    </f:content>
                </f:SimpleForm>
            </VBox>

            <VBox class="sapUiSmallMargin">
                <Toolbar>
                    <Title text="Enter Weight (Item Details)" />
                    <ToolbarSpacer />
                    <Button
                        text="Add Row"
                        icon="sap-icon://add"
                        type="Emphasized"
                        press="onAddRow"
                        class="sapUiTinyMarginBegin"
                    />
                </Toolbar>
                <Table
                    id="idItemTable"
                    items="{ItemModel>/results}"
                    growing="true"
                    growingThreshold="20"
                >
                    <columns>
                        <Column>
                            <Text text="Serial No" />
                        </Column>

                        <Column>
                            <Text text="Invoice No" />
                        </Column>

                        <Column>
                            <Text text="Invoice Date" />
                        </Column>
                        <Column>
                            <Text text="Purchase Order No" />
                        </Column>
                        <Column>
                            <Text text="Purchase Order Item" />
                        </Column>
                        <Column>
                            <Text text="Material" />
                        </Column>
                        <Column>
                            <Text text="Quantity" />
                        </Column>
                        <Column width="80px">
                            <Text text="Delete" />
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{ItemModel>Sino}" />
                                <Input
                                    value="{ItemModel>Invoiceno}"
                                    liveChange=".onFieldChange"
                                />

                                <DatePicker
                                    value="{ItemModel>Invoicedt}"
                                    displayFormat="dd-MM-yyyy"
                                    valueFormat="yyyy-MM-ddTHH:mm:ss"
                                    change=".onFieldChange"
                                />

                                <!-- <Input
                                    value="{ItemModel>Pono}"
                                    liveChange=".onFieldChange"
                                /> -->
                                <ComboBox
                                    width="100%"
                                    selectedKey="{ItemModel>Pono}"
                                    selectionChange="onPurchaseOrderChange"
                                    items="{ItemModel>poNoItems}"
                                >
                                    <core:Item
                                        key="{ItemModel>purchaseorderno}"
                                        text="{ItemModel>purchaseorderno}"
                                    />
                                </ComboBox>
                                <!-- <Input
                                    value="{ItemModel>Poitem}"
                                    liveChange=".onFieldChange"
                                /> -->

                                <ComboBox
                                    width="100%"
                                    selectedKey="{ItemModel>Poitem}"
                                    selectionChange="onPurchaseOrderItemChange"
                                    items="{ItemModel>poItemItems}"
                                >
                                    <core:Item
                                        key="{ItemModel>purchaseorderitem}"
                                        text="{ItemModel>purchaseorderitem}"
                                    />
                                </ComboBox>

                                <Input
                                    value="{ItemModel>Matnr}"
                                    liveChange=".onFieldChange"
                                />

                                <Input
                                    value="{ItemModel>Qty}"
                                    liveChange=".onFieldChange"
                                />

                                <Button
                                    icon="sap-icon://delete"
                                    press=".onDeleteRow"
                                />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>
